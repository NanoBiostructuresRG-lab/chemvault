import requests
import json

protein = "P34971"   # Beta-1 adrenergic receptor (house mouse)

BASE_URL = "https://pubchem.ncbi.nlm.nih.gov/rest/pug"

# -----------------------------
# Paso 1: Obtener AIDs
# -----------------------------
url_aids = f"{BASE_URL}/assay/target/accession/{protein}/aids/JSON"

response = requests.get(url_aids, timeout=30)
response.raise_for_status()

data = response.json()

aids = data["IdentifierList"]["AID"]

print("AIDs encontrados:", aids)

# Guardar JSON de AIDs
aids_json = {
    "protein": protein,
    "total_aids": len(aids),
    "aids": aids
}

with open(f"{protein}_aids.json", "w", encoding="utf-8") as f:
    json.dump(aids_json, f, indent=4)

print(f"Archivo guardado: {protein}_aids.json")

# -----------------------------
# Paso 2: Obtener CIDs
# -----------------------------
all_cids = set() #usamos sets para que no se repitan elementos 

for aid in aids:
    try:
        url_cids = f"{BASE_URL}/assay/aid/{aid}/cids/JSON"
        print(url_cids)

        response = requests.get(url_cids, timeout=30)
        response.raise_for_status()

        cid_data = response.json()

        cids = cid_data['InformationList']['Information'][0]['CID']

        all_cids.update(cids)   # agrega sin repetir, usamos update, porque son multiples elementos 

    except Exception as e:
        print(f"Error con AID {aid}: {e}")

# Convertir a lista ordenada
all_cids = sorted(list(all_cids))

# Guardar JSON de CIDs
cids_json = {
    "protein": protein,
    "total_unique_cids": len(all_cids),
    "cids": all_cids
}

with open(f"{protein}_cids.json", "w", encoding="utf-8") as f:
    json.dump(cids_json, f, indent=4)

print(f"Archivo guardado: {protein}_cids.json")

# -----------------------------
# Resumen final
# -----------------------------
print("\nTotal CIDs únicos encontrados:", len(all_cids))